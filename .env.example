# ---------------------------------------------------------------------------
# Arv — environment variables. Copy to `.env.local` and fill in.
# ---------------------------------------------------------------------------

# Supabase (public — safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Supabase service role (server only — NEVER expose to the browser).
# Used by background jobs that must bypass RLS (import pipeline, exports).
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Providers (all optional in the foundation phase; stubs are used) -------

# Anthropic — powers the import agent (recipe extraction + rewrite to house
# style, in Norwegian). REQUIRED for import to do more than a crude text parse:
# without it, pasted text falls back to a heuristic stub and URLs can't be read.
# Get a key at console.anthropic.com and set it here (local) and in the host's
# env (e.g. Vercel → Project → Settings → Environment Variables).
ANTHROPIC_API_KEY=

# Transcription provider ("Listen" layer). Leave unset to use the stub.
# TRANSCRIPTION_PROVIDER=whisper
OPENAI_API_KEY=

# Media fetch provider (Instagram/TikTok). Leave unset to use the stub.
# MEDIA_FETCH_PROVIDER=apify
# APIFY_TOKEN=

# Print-on-demand provider. Defaults to the stubbed gelato adapter.
# PRINT_PROVIDER=gelato
# GELATO_API_KEY=

# ---- Feature flags ---------------------------------------------------------
# Order-hardcover flow is off by default; MVP ships "download print-ready PDF".
NEXT_PUBLIC_FLAG_ORDER_HARDCOVER=false
# Stripe is stubbed behind a flag.
NEXT_PUBLIC_FLAG_BILLING=false
STRIPE_SECRET_KEY=
